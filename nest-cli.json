{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/user/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": false,
    "tsConfigPath": "apps/user/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/user",
  "projects": {
    "user": {
      "type": "application",
      "root": "apps/user",
      "entryFile": "main",
      "sourceRoot": "apps/user/src",
      "compilerOptions": {
        "webpack": false,
        "tsConfigPath": "apps/user/tsconfig.app.json",
        "assets": [
          {
            "include": "proto/**/*.proto",
            "outDir": "dist/apps/user",
            "watchAssets": true
          }
        ]
      }
    },
    "wallet": {
      "type": "application",
      "root": "apps/wallet",
      "entryFile": "main",
      "sourceRoot": "apps/wallet/src",
      "compilerOptions": {
        "webpack": false,
        "tsConfigPath": "apps/wallet/tsconfig.app.json",
        "assets": [
          {
            "include": "../../proto/**/*.proto",
            "outDir": "dist/apps/wallet/proto",
            "watchAssets": true
          }
        ]
      }
    }
  }
}